{
  "headers": [
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "text/css; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/robots.txt",  "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/llms.txt",    "dest": "/llms.txt" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/growth-logs/(.+)\\.html", "dest": "/growth-logs/$1.html" },
    { "src": "/growth-logs/(.+)", "dest": "/growth-logs/$1.html" },
    { "src": "/growth-logs/?", "dest": "/growth-logs.html" },
    { "src": "/(.*\\.(css|js|svg|png|jpg|jpeg|ico|pdf|webp|woff|woff2|ttf))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
